{
  "name": "slidespeak-onbrand",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "prisma generate && tsc --noEmit",
    "lint": "prisma generate && eslint .",
    "format": "prettier --check .",
    "test": "prisma generate && vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "24.10.3",
    "eslint": "9.39.2",
    "prettier": "3.8.4",
    "prisma": "7.8.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.1",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@onbrand/env": "workspace:*",
    "@aws-sdk/client-s3": "3.1067.0",
    "@aws-sdk/s3-request-presigner": "3.1067.0",
    "@hono/node-server": "2.0.4",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "hono": "4.12.25",
    "jose": "6.2.3",
    "pg": "8.21.0"
  }
}
