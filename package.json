{
  "name": "slidespeak-onbrand-workspace",
  "version": "0.3.1",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SlideSpeak/slidespeak-onbrand.git"
  },
  "bugs": {
    "url": "https://github.com/SlideSpeak/slidespeak-onbrand/issues"
  },
  "homepage": "https://github.com/SlideSpeak/slidespeak-onbrand#readme",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "mcp": "tsx packages/mcp-server/src/server/http.ts",
    "build": "prisma generate && vite build --config vite.config.ts && vite build --config packages/dashboard/vite.config.ts packages/dashboard",
    "typecheck": "prisma generate && tsc --noEmit",
    "lint": "prisma generate && eslint .",
    "react-doctor": "react-doctor packages/dashboard",
    "react-doctor:score": "react-doctor packages/dashboard --score",
    "react-doctor:check": "test \"$(bun run --silent react-doctor:score)\" = \"100\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tailwind:format": "prettier --write packages/dashboard/src/**/*.{ts,tsx,css}",
    "tailwind:check": "prettier --check packages/dashboard/src/**/*.{ts,tsx,css}",
    "shadcn:info": "shadcn info --cwd packages/dashboard",
    "shadcn:add": "shadcn add --cwd packages/dashboard",
    "test": "prisma generate && vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "25.9.2",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "7.8.0",
    "react-doctor": "^0.5.6",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1067.0",
    "@aws-sdk/s3-request-presigner": "3.1067.0",
    "@hono/node-server": "2.0.4",
    "@hugeicons/core-free-icons": "4.2.0",
    "@hugeicons/react": "1.1.7",
    "@mdxeditor/editor": "^4.0.0",
    "@onbrand/env": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-router": "^1.170.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color-sorter": "8.0.0",
    "colorjs.io": "0.6.1",
    "hono": "4.12.25",
    "jose": "6.2.3",
    "openbrand": "0.2.3",
    "pg": "8.21.0",
    "react": "^19.2.7",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  }
}
