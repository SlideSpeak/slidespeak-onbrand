{
  "name": "slidespeak-onbrand-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "mcp": "tsx packages/onbrand/src/mcp-server/stdio.ts",
    "build": "cd packages/onbrand && vite build --config ../../vite.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.61.0",
    "vite": "latest",
    "vitest": "latest"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.21.0"
  }
}
