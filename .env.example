# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Optional for local CLI use. Defaults to localhost:5433 in Prisma/app code.
# Required for Docker.
DATABASE_URL="postgresql://onbrand:onbrand@postgres:5432/onbrand?schema=public"

# -----------------------------------------------------------------------------
# HTTP MCP
# -----------------------------------------------------------------------------
# Required by the remote MCP HTTP server.
BASE_URL="http://localhost:8080"

# -----------------------------------------------------------------------------
# SlideSpeak OAuth
# -----------------------------------------------------------------------------
# Required by the remote MCP HTTP server.
SLIDESPEAK_OAUTH_ISSUER="http://localhost:3000"
# Optional. Defaults to SLIDESPEAK_OAUTH_ISSUER. Use this for server-to-server calls from Docker.
SLIDESPEAK_OAUTH_BACKCHANNEL_BASE_URL="http://host.docker.internal:3000"
# Optional. Defaults to ${SLIDESPEAK_OAUTH_BACKCHANNEL_BASE_URL}/oauth/jwks.json.
SLIDESPEAK_JWKS_URL="http://host.docker.internal:3000/oauth/jwks.json"
# Static first-party OAuth client registered in SlideSpeak for the Onbrand Dashboard.
DASHBOARD_OAUTH_CLIENT_ID="onbrand-dashboard"
# Required in production. Use a long random value, for example: openssl rand -hex 32
DASHBOARD_SESSION_SECRET="dev-onbrand-dashboard-session-secret"

# -----------------------------------------------------------------------------
# S3
# -----------------------------------------------------------------------------
# Optional. Defaults to 900.
ASSET_DOWNLOAD_EXPIRES_IN_SECONDS="900"
# Required for S3 access.
AWS_S3_BUCKET_BRAND_KIT_ASSETS="onbrand-brand-kit-assets"
AWS_REGION="us-east-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
