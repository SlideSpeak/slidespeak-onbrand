# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Optional for local CLI use. Defaults to localhost:5433 in Prisma/app code.
# Required for Docker.
DATABASE_URL="postgresql://onbrand:onbrand@postgres:5432/onbrand?schema=public"

# -----------------------------------------------------------------------------
# HTTP MCP
# -----------------------------------------------------------------------------
# Required by the remote MCP HTTP server.
BASE_URL="http://localhost:8080"

# -----------------------------------------------------------------------------
# OAuth provider
# -----------------------------------------------------------------------------
# Required by the remote MCP HTTP server. These localhost values are generic
# development examples for any compatible OAuth provider.
OAUTH_ISSUER="http://localhost:3000"
OAUTH_AUTHORIZATION_ENDPOINT="http://localhost:3000/oauth/authorize"
# Public token endpoint advertised in OAuth metadata and used by MCP clients.
OAUTH_TOKEN_ENDPOINT="http://localhost:3000/oauth/token"
# Optional. Defaults to OAUTH_TOKEN_ENDPOINT. Use this for server-to-server token exchanges from Docker.
OAUTH_BACKCHANNEL_TOKEN_ENDPOINT="http://host.docker.internal:3000/oauth/token"
OAUTH_JWKS_URL="http://host.docker.internal:3000/oauth/jwks.json"
# Optional dynamic client registration endpoint.
OAUTH_REGISTRATION_ENDPOINT="http://localhost:3000/oauth/register"
# Static first-party OAuth client registered for the OnBrand Dashboard.
OAUTH_DASHBOARD_CLIENT_ID="onbrand-dashboard"
# Optional. Defaults are onbrand:read, onbrand:write, and sub.
OAUTH_REQUIRED_READ_SCOPE="onbrand:read"
OAUTH_REQUIRED_WRITE_SCOPE="onbrand:write"
OAUTH_OWNER_ID_CLAIM="sub"
# Required in production. Use a long random value, for example: openssl rand -hex 32
DASHBOARD_SESSION_SECRET="replace-with-a-long-random-local-secret"

# -----------------------------------------------------------------------------
# S3
# -----------------------------------------------------------------------------
# Optional. Defaults to 900.
ASSET_DOWNLOAD_EXPIRES_IN_SECONDS="900"
# Required for S3 access. Use a dedicated development bucket and least-privilege credentials.
AWS_S3_BUCKET_BRAND_KIT_ASSETS="onbrand-dev-brand-kit-assets"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="replace-with-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="replace-with-aws-secret-access-key"
